# .env.example
# Non-secret environment variable template.
# Copy this to .env and fill in real values on Schubert.
# NEVER commit .env to source control.
# NEVER put real secret values in this file.

# ── Application ───────────────────────────────────────────────────────────────
# APP_NAME=[PROJECT NAME]
# APP_ENV=production
# PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ── External Services ─────────────────────────────────────────────────────────
# API_KEY=your-api-key-here

# ── LiteLLM (Schubert shared proxy) ──────────────────────────────────────────
# LITELLM_BASE_URL=http://localhost:4000
# LITELLM_MASTER_KEY=your-litellm-key-here
